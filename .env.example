# Copy this file to .env before starting Docker or the deployment scripts.
# Do not commit the populated .env file.
MYSQL_ROOT_PASSWORD=replace-with-a-strong-password
MYSQL_USERNAME=root
REDIS_PASSWORD=replace-with-a-strong-password
JWT_SECRET=replace-with-a-random-secret-at-least-32-bytes-long
# Required only until the first owner account is created; generate a unique secret.
OWNER_INIT_TOKEN=replace-with-a-one-time-owner-initialization-token
MYSQL_HOST=mysql
REDIS_HOST=redis
# Docker deployment uses the hardened production profile. Use dev for direct local runs.
SPRING_PROFILES_ACTIVE=prod
SERVER_ADDRESS=0.0.0.0
# Bind the gateway only to loopback. Change this when 8080 is already occupied.
GATEWAY_HOST_PORT=8080
CORS_ALLOWED_ORIGIN_PATTERN=https://your-domain.example
MEDIA_MAX_BYTES=5242880
# local uses the Docker volume below. Set s3 for AWS S3, MinIO, R2 or another compatible provider.
MEDIA_STORAGE_TYPE=local
MEDIA_S3_ENDPOINT=
MEDIA_S3_REGION=us-east-1
MEDIA_S3_BUCKET=
MEDIA_S3_ACCESS_KEY=
MEDIA_S3_SECRET_KEY=
MEDIA_S3_PATH_STYLE=true
MEDIA_S3_PREFIX=product-media
# Used only by backup/restore when MEDIA_STORAGE_TYPE=s3.
BACKUP_AWS_CLI_IMAGE=amazon/aws-cli:2.27.55
LOW_STOCK_THRESHOLD=5
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=
# Optional durable order-event webhook. When enabled, the secret must contain at least 32 characters.
ORDER_WEBHOOK_ENABLED=false
ORDER_WEBHOOK_URL=
ORDER_WEBHOOK_SECRET=
ORDER_WEBHOOK_MAX_ATTEMPTS=6
# Required by ./start.sh backup and restore. Use a different strong secret from the database password.
BACKUP_ENCRYPTION_PASSWORD=replace-with-a-long-random-backup-passphrase
BACKUP_RETENTION_DAYS=14
# Keep this value when using docker/docker-compose.app.yml.
PRODUCT_MEDIA_VOLUME=biyesheji-app_product-media
# Observability UIs remain bound to loopback; use an SSH tunnel to access them.
PROMETHEUS_HOST_PORT=19090
ALERTMANAGER_HOST_PORT=19093
PROMETHEUS_RETENTION=15d
